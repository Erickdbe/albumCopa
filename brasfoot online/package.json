{
  "name": "brfut",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:api": "npm run dev -w @brfut/api",
    "dev:worker": "npm run dev -w @brfut/worker",
    "dev:realtime": "npm run dev -w @brfut/realtime",
    "dev:web": "npm run dev -w @brfut/web",
    "db:migrate": "npm run migrate -w @brfut/db",
    "db:seed": "npm run seed -w @brfut/db"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
