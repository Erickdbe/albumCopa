generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum PlayerPosition {
  GK
  CB
  LB
  RB
  DM
  CM
  AM
  LW
  RW
  ST
}

enum PreferredFoot {
  LEFT
  RIGHT
  BOTH
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

enum SeasonStatus {
  UPCOMING
  ACTIVE
  FINISHED
}

enum MatchEventType {
  GOAL
  OWN_GOAL
  PENALTY_GOAL
  PENALTY_MISSED
  YELLOW_CARD
  RED_CARD
  INJURY
  SUBSTITUTION
  CHANCE_MISSED
  KICK_OFF
  HALF_TIME
  FULL_TIME
}

enum TransferType {
  PURCHASE
  LOAN
  FREE
}

enum TransferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

enum ListingStatus {
  OPEN
  SOLD
  EXPIRED
  CANCELLED
}

// ---------- Core entities ----------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  username     String   @unique
  createdAt    DateTime @default(now()) @map("created_at")

  clubs         Club[]
  transfersMade Transfer[]     @relation("TransferInitiator")
  notifications Notification[]
  ownedLeagues  League[]       @relation("LeagueOwner")

  @@map("users")
}

model League {
  id      String       @id @default(uuid())
  name    String
  country String
  tier    Int          @default(1)
  format  String       @default("round_robin") // round_robin | groups_knockout
  maxClubs Int         @map("max_clubs") @default(20)

  // seconds of real time per simulated match-minute during live broadcast;
  // lets each league run "compressed" or closer to real-time playback
  playbackSecondsPerMinute Int @default(2) @map("playback_seconds_per_minute")

  // Private rooms don't show up in GET /leagues — only reachable by ID
  // (the ID doubles as the invite link). Publicly-listed leagues (the ones
  // the CLI seed creates) are isPrivate: false.
  isPrivate Boolean @default(false) @map("is_private")
  ownerId   String? @map("owner_id")
  owner     User?   @relation("LeagueOwner", fields: [ownerId], references: [id])

  clubs   Club[]
  seasons Season[]

  @@map("leagues")
}

model Season {
  id        String       @id @default(uuid())
  leagueId  String       @map("league_id")
  league    League       @relation(fields: [leagueId], references: [id])
  name      String
  startDate DateTime     @map("start_date")
  endDate   DateTime     @map("end_date")
  status    SeasonStatus @default(UPCOMING)

  standings Standing[]
  matches   Match[]

  @@index([leagueId])
  @@map("seasons")
}

model Club {
  id               String  @id @default(uuid())
  userId           String? @unique @map("user_id")
  user             User?   @relation(fields: [userId], references: [id])
  leagueId         String? @map("league_id")
  league           League? @relation(fields: [leagueId], references: [id])

  name             String
  shortName        String  @map("short_name")
  stadiumName      String  @map("stadium_name")
  stadiumCapacity  Int     @map("stadium_capacity")
  balance          Decimal @default(0) @db.Decimal(14, 2)
  reputation       Int     @default(50)

  formation        String  @default("4-4-2")
  tacticStyle      Json?   @map("tactic_style")

  createdAt        DateTime @default(now()) @map("created_at")

  players            Player[]
  homeMatches        Match[]           @relation("HomeClub")
  awayMatches        Match[]           @relation("AwayClub")
  standings          Standing[]
  matchLineups       MatchLineup[]
  transfersFrom      Transfer[]        @relation("TransferFromClub")
  transfersTo        Transfer[]        @relation("TransferToClub")
  listingsAsSeller   TransferListing[] @relation("ListingSeller")
  bids               Bid[]

  @@index([leagueId])
  @@map("clubs")
}

model Player {
  id                String          @id @default(uuid())
  clubId            String?         @map("club_id")
  club              Club?           @relation(fields: [clubId], references: [id])

  name              String
  birthDate         DateTime        @map("birth_date")
  nationality       String
  position          PlayerPosition
  preferredFoot     PreferredFoot   @map("preferred_foot")

  // gameplay attributes, 1-99. Generated (not sourced from any public API).
  pace              Int
  finishing         Int
  passing           Int
  dribbling         Int
  tackling          Int
  strength          Int
  stamina           Int
  gkReflexes        Int             @map("gk_reflexes")
  gkPositioning     Int             @map("gk_positioning")

  overall           Int
  potential         Int
  morale            Int             @default(70)
  fitness           Int             @default(100)
  form              Int             @default(50)

  injuryStatus      String?         @map("injury_status")
  injuryReturnDate  DateTime?       @map("injury_return_date")

  contractEndDate   DateTime?       @map("contract_end_date")
  wage              Decimal?        @db.Decimal(12, 2)
  releaseClause     Decimal?        @map("release_clause") @db.Decimal(14, 2)
  marketValue       Decimal         @default(0) @map("market_value") @db.Decimal(14, 2)

  externalRef       String?         @map("external_ref") // id from source football API, if imported

  createdAt         DateTime        @default(now()) @map("created_at")

  matchLineups      MatchLineup[]
  eventsAsPlayer    MatchEvent[]    @relation("EventPlayer")
  eventsAsRelated   MatchEvent[]    @relation("EventRelatedPlayer")
  transfers         Transfer[]
  listings          TransferListing[]

  @@index([clubId])
  @@map("players")
}

model Standing {
  seasonId String @map("season_id")
  season   Season @relation(fields: [seasonId], references: [id])
  clubId   String @map("club_id")
  club     Club   @relation(fields: [clubId], references: [id])

  played     Int @default(0)
  wins       Int @default(0)
  draws      Int @default(0)
  losses     Int @default(0)
  goalsFor   Int @default(0) @map("goals_for")
  goalsAgainst Int @default(0) @map("goals_against")
  points     Int @default(0)

  @@id([seasonId, clubId])
  @@index([seasonId, points])
  @@map("standings")
}

model Match {
  id             String      @id @default(uuid())
  seasonId       String      @map("season_id")
  season         Season      @relation(fields: [seasonId], references: [id])
  roundNumber    Int         @map("round_number")

  homeClubId     String      @map("home_club_id")
  homeClub       Club        @relation("HomeClub", fields: [homeClubId], references: [id])
  awayClubId     String      @map("away_club_id")
  awayClub       Club        @relation("AwayClub", fields: [awayClubId], references: [id])

  scheduledAt    DateTime    @map("scheduled_at")
  status         MatchStatus @default(SCHEDULED)
  homeScore      Int?        @map("home_score")
  awayScore      Int?        @map("away_score")

  simulationSeed String?     @map("simulation_seed")

  lineups MatchLineup[]
  events  MatchEvent[]

  @@index([status, scheduledAt])
  @@index([seasonId, roundNumber])
  @@map("matches")
}

model MatchLineup {
  id          String  @id @default(uuid())
  matchId     String  @map("match_id")
  match       Match   @relation(fields: [matchId], references: [id])
  clubId      String  @map("club_id")
  club        Club    @relation(fields: [clubId], references: [id])
  playerId    String  @map("player_id")
  player      Player  @relation(fields: [playerId], references: [id])

  isStarting  Boolean @default(true) @map("is_starting")
  position    PlayerPosition
  shirtNumber Int     @map("shirt_number")
  rating      Decimal? @db.Decimal(3, 1)

  @@index([matchId])
  @@map("match_lineups")
}

model MatchEvent {
  id              String         @id @default(uuid())
  matchId         String         @map("match_id")
  match           Match          @relation(fields: [matchId], references: [id])
  minute          Int
  second          Int            @default(0)
  type            MatchEventType
  teamSide        String         @map("team_side") // "home" | "away"

  playerId        String?        @map("player_id")
  player          Player?        @relation("EventPlayer", fields: [playerId], references: [id])
  relatedPlayerId String?        @map("related_player_id")
  relatedPlayer   Player?        @relation("EventRelatedPlayer", fields: [relatedPlayerId], references: [id])

  metadata        Json?
  createdAt       DateTime       @default(now()) @map("created_at")

  @@index([matchId, minute])
  @@map("match_events")
}

// ---------- Transfer market ----------

model Transfer {
  id          String         @id @default(uuid())
  playerId    String         @map("player_id")
  player      Player         @relation(fields: [playerId], references: [id])
  fromClubId  String?        @map("from_club_id")
  fromClub    Club?          @relation("TransferFromClub", fields: [fromClubId], references: [id])
  toClubId    String         @map("to_club_id")
  toClub      Club           @relation("TransferToClub", fields: [toClubId], references: [id])

  type        TransferType
  value       Decimal        @db.Decimal(14, 2)
  status      TransferStatus @default(PENDING)

  initiatedByUserId String   @map("initiated_by_user_id")
  initiatedByUser   User     @relation("TransferInitiator", fields: [initiatedByUserId], references: [id])

  createdAt   DateTime       @default(now()) @map("created_at")
  completedAt DateTime?      @map("completed_at")

  @@index([playerId])
  @@map("transfers")
}

model TransferListing {
  id                 String        @id @default(uuid())
  playerId           String        @map("player_id")
  player             Player        @relation(fields: [playerId], references: [id])
  sellerClubId       String        @map("seller_club_id")
  sellerClub         Club          @relation("ListingSeller", fields: [sellerClubId], references: [id])

  startingPrice      Decimal       @map("starting_price") @db.Decimal(14, 2)
  buyNowPrice        Decimal?      @map("buy_now_price") @db.Decimal(14, 2)
  currentBid         Decimal?      @map("current_bid") @db.Decimal(14, 2)
  currentBidderClubId String?      @map("current_bidder_club_id")

  endsAt             DateTime      @map("ends_at")
  status             ListingStatus @default(OPEN)

  bids               Bid[]

  @@index([status, endsAt])
  @@map("transfer_listings")
}

model Bid {
  id             String          @id @default(uuid())
  listingId      String          @map("listing_id")
  listing        TransferListing @relation(fields: [listingId], references: [id])
  bidderClubId   String          @map("bidder_club_id")
  bidderClub     Club            @relation(fields: [bidderClubId], references: [id])
  amount         Decimal         @db.Decimal(14, 2)
  createdAt      DateTime        @default(now()) @map("created_at")

  @@index([listingId])
  @@map("bids")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  type      String
  payload   Json
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, readAt])
  @@map("notifications")
}
